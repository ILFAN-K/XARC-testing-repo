PORT=3001
DATABASE_URL="postgresql://user:password@localhost:5432/xarc_db?schema=public"

JWT_SECRET="your-secret-jwt-key"
JWT_EXPIRES_IN="1d"

FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@your-project-id.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# CORS origins (comma-separated). Required for production.
CORS_ORIGINS="https://your-frontend-domain.com"

# Agent WebSocket authentication key. Required for production.
AGENT_SECRET_KEY="your-agent-secret-key"

# Auth bypass (set to 'true' only for local development without Firebase)
AUTH_BYPASS=false

# Minimum aggregator version required on devices
MINIMUM_AGGREGATOR_VERSION=2.0.0

# Aggregator installer configuration
AGGREGATOR_INSTALLER_URL="https://your-cdn.com/aggregator-installer.exe"
AGGREGATOR_INSTALLER_ARGS="/S"
AGGREGATOR_EXPECTED_VERSION="2.0.0"

# Email invite base URL (frontend URL for invitation links)
INVITE_BASE_URL="https://your-frontend-domain.com/invite"
